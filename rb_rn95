<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>RB Ai</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root { --sidebar-width: 280px; }
        body { font-family: 'Inter', system-ui, -apple-system, sans-serif; transition: background-color 0.3s; }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark::-webkit-scrollbar-thumb { background: #475569; }

        #loading {
            position: fixed; inset: 0; background: white; z-index: 9999;
            display: flex; align-items: center; justify-content: center; font-weight: 600;
        }
        .dark #loading { background: #111827; color: white; }

        .chat-container { height: calc(100svh - 140px); }
        .sidebar { transition: transform 0.3s ease; z-index: 50; }
        
        /* Message styling */
        .prose pre { background: #1e293b; color: #f8fafc; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 0.5rem 0; }
        .prose code { color: #e11d48; }
        .dark .prose { color: #e2e8f0; }
        .dark .prose strong { color: #fff; }
        
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); position: fixed; height: 100%; }
            .sidebar.open { transform: translateX(0); }
            .chat-container { height: calc(100svh - 160px); }
        }

        .typing-cursor::after { content: "|"; animation: blink 1s infinite; }
        @keyframes blink { 50% { opacity: 0; } }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-[#131314] dark:text-gray-200 min-h-screen flex">

    <div id="loading">Initialising RB Ai...</div>

    <aside id="sidebar" class="sidebar bg-gray-100 dark:bg-[#1e1f20] w-[280px] flex-shrink-0 flex flex-col border-r border-gray-200 dark:border-gray-700">
        <div class="p-4">
            <button onclick="createNewChat()" class="w-full flex items-center gap-3 px-4 py-3 bg-gray-200 dark:bg-[#28292a] hover:bg-gray-300 dark:hover:bg-[#333537] rounded-full transition-all text-sm font-medium">
                <i class="fa-solid fa-plus text-lg"></i>
                New Chat
            </button>
        </div>

        <div id="chat-history" class="flex-1 overflow-y-auto px-3 space-y-1">
            </div>

        <div class="p-4 border-t border-gray-200 dark:border-gray-700 space-y-2">
            <button onclick="toggleDarkMode()" class="w-full flex items-center gap-3 px-4 py-2 hover:bg-gray-200 dark:hover:bg-[#333537] rounded-lg text-sm">
                <i class="fa-solid fa-moon"></i> Appearance
            </button>
            <button onclick="openSettings()" class="w-full flex items-center gap-3 px-4 py-2 hover:bg-gray-200 dark:hover:bg-[#333537] rounded-lg text-sm">
                <i class="fa-solid fa-gear"></i> Settings
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative w-full overflow-hidden">
        <header class="p-4 flex items-center justify-between lg:justify-end">
            <button onclick="toggleSidebar()" class="lg:hidden p-2 text-xl"><i class="fa-solid fa-bars"></i></button>
            <h1 class="text-xl font-semibold text-blue-600 dark:text-white lg:hidden">RB Ai</h1>
            <div class="hidden lg:block text-sm opacity-50 font-mono" id="current-model-tag"></div>
        </header>

        <div id="chat-window" class="chat-container flex-1 overflow-y-auto p-4 md:px-[15%] space-y-6">
            <div id="empty-state" class="h-full flex flex-col items-center justify-center text-center space-y-4">
                <div class="text-4xl font-bold bg-gradient-to-r from-blue-500 via-purple-500 to-red-500 bg-clip-text text-transparent">Hello BOSS</div>
                <p class="text-gray-500 dark:text-gray-400">How can I help you today?</p>
            </div>
            <div id="messages-list" class="space-y-8"></div>
        </div>

        <div class="p-4 md:px-[15%] bg-white dark:bg-[#131314]">
            <div class="relative max-w-4xl mx-auto flex items-end gap-2 bg-gray-100 dark:bg-[#1e1f20] rounded-2xl p-2 border border-transparent focus-within:border-blue-500">
                <textarea id="user-input" rows="1" placeholder="Message RB Ai..." 
                    class="w-full bg-transparent border-none focus:ring-0 p-2 resize-none max-h-40 overflow-y-auto text-sm md:text-base"
                    oninput="this.style.height = '';this.style.height = this.scrollHeight + 'px'"></textarea>
                <button onclick="sendMessage()" id="send-btn" class="p-2 px-4 bg-blue-600 hover:bg-blue-700 text-white rounded-xl transition-all disabled:opacity-30">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </div>
            <p class="text-[10px] text-center mt-2 opacity-50">AI can make mistakes. Check important info.</p>
        </div>
    </main>

    <div id="settings-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white dark:bg-[#1e1f20] w-full max-w-md rounded-2xl p-6 shadow-2xl">
            <h2 class="text-xl font-bold mb-4">Settings</h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold uppercase mb-1 opacity-60">OpenRouter API Key</label>
                    <input type="password" id="api-key" class="w-full p-2 rounded bg-gray-100 dark:bg-[#28292a] border-none">
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase mb-1 opacity-60">Model Name</label>
                    <input type="text" id="model-name" placeholder="deepseek/deepseek-r1:free" class="w-full p-2 rounded bg-gray-100 dark:bg-[#28292a] border-none">
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase mb-1 opacity-60">System Prompt</label>
                    <textarea id="system-prompt" rows="3" class="w-full p-2 rounded bg-gray-100 dark:bg-[#28292a] border-none text-sm"></textarea>
                </div>
            </div>
            <div class="mt-6 flex justify-end gap-3">
                <button onclick="closeSettings()" class="px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg">Cancel</button>
                <button onclick="saveSettings()" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-bold">Save Changes</button>
            </div>
        </div>
    </div>

    <script>
        // --- State Management ---
        let state = {
            apiKey: localStorage.getItem('or_key') || '',
            model: localStorage.getItem('or_model') || 'deepseek/deepseek-r1:free',
            systemPrompt: localStorage.getItem('or_system') || 'You are RB Ai, a helpful assistant.',
            chats: JSON.parse(localStorage.getItem('or_chats')) || [],
            currentChatId: null,
            isDark: localStorage.getItem('or_theme') === 'dark'
        };

        // --- Initialization ---
        window.onload = () => {
            if (state.isDark) document.documentElement.classList.add('dark');
            renderHistory();
            updateModelTag();
            
            // Auto-open settings if no key
            if (!state.apiKey) openSettings();
            
            document.getElementById('loading').style.display = 'none';
        };

        // --- UI Logic ---
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
        }

        function toggleDarkMode() {
            state.isDark = !state.isDark;
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('or_theme', state.isDark ? 'dark' : 'light');
        }

        function openSettings() {
            document.getElementById('api-key').value = state.apiKey;
            document.getElementById('model-name').value = state.model;
            document.getElementById('system-prompt').value = state.systemPrompt;
            document.getElementById('settings-modal').classList.remove('hidden');
        }

        function closeSettings() {
            document.getElementById('settings-modal').classList.add('hidden');
        }

        function saveSettings() {
            state.apiKey = document.getElementById('api-key').value;
            state.model = document.getElementById('model-name').value || 'deepseek/deepseek-r1:free';
            state.systemPrompt = document.getElementById('system-prompt').value;
            
            localStorage.setItem('or_key', state.apiKey);
            localStorage.setItem('or_model', state.model);
            localStorage.setItem('or_system', state.systemPrompt);
            
            updateModelTag();
            closeSettings();
        }

        function updateModelTag() {
            document.getElementById('current-model-tag').innerText = `Model: ${state.model}`;
        }

        // --- Chat Logic ---
        function createNewChat() {
            const newChat = {
                id: Date.now(),
                title: 'New Conversation',
                messages: []
            };
            state.chats.unshift(newChat);
            state.currentChatId = newChat.id;
            saveChats();
            renderHistory();
            renderMessages();
            if(window.innerWidth < 1024) toggleSidebar();
        }

        function switchChat(id) {
            state.currentChatId = id;
            renderMessages();
            if(window.innerWidth < 1024) toggleSidebar();
        }

        function deleteChat(id, e) {
            e.stopPropagation();
            state.chats = state.chats.filter(c => c.id !== id);
            if (state.currentChatId === id) state.currentChatId = null;
            saveChats();
            renderHistory();
            renderMessages();
        }

        function saveChats() {
            localStorage.setItem('or_chats', JSON.stringify(state.chats));
        }

        function renderHistory() {
            const container = document.getElementById('chat-history');
            container.innerHTML = state.chats.map(chat => `
                <div onclick="switchChat(${chat.id})" class="group flex items-center justify-between p-3 rounded-lg cursor-pointer ${state.currentChatId === chat.id ? 'bg-blue-100/50 dark:bg-[#333537]' : 'hover:bg-gray-200 dark:hover:bg-[#28292a]'}">
                    <div class="flex items-center gap-3 overflow-hidden">
                        <i class="fa-regular fa-message opacity-60"></i>
                        <span class="truncate text-sm">${chat.title}</span>
                    </div>
                    <button onclick="deleteChat(${chat.id}, event)" class="opacity-0 group-hover:opacity-100 p-1 hover:text-red-500"><i class="fa-solid fa-trash-can text-xs"></i></button>
                </div>
            `).join('');
        }

        function renderMessages() {
            const list = document.getElementById('messages-list');
            const empty = document.getElementById('empty-state');
            const chat = state.chats.find(c => c.id === state.currentChatId);

            if (!chat || chat.messages.length === 0) {
                list.innerHTML = '';
                empty.style.display = 'flex';
                return;
            }

            empty.style.display = 'none';
            list.innerHTML = chat.messages.map(m => `
                <div class="flex ${m.role === 'user' ? 'justify-end' : 'justify-start'} animate-in fade-in duration-300">
                    <div class="max-w-[85%] ${m.role === 'user' ? 'bg-gray-200 dark:bg-[#2f2f2f] rounded-2xl px-4 py-2' : 'w-full'}">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-[10px] font-bold uppercase tracking-widest opacity-50">
                                ${m.role === 'user' ? 'You' : 'RB Ai'}
                            </span>
                        </div>
                        <div class="prose prose-sm dark:prose-invert max-w-none">
                            ${marked.parse(m.content)}
                        </div>
                    </div>
                </div>
            `).join('');
            
            const win = document.getElementById('chat-window');
            win.scrollTo({ top: win.scrollHeight, behavior: 'smooth' });
        }

        // --- API Integration ---
        async function sendMessage() {
            const input = document.getElementById('user-input');
            const btn = document.getElementById('send-btn');
            const content = input.value.trim();

            if (!content || !state.apiKey) {
                if(!state.apiKey) openSettings();
                return;
            }

            // 1. Setup Chat if none selected
            if (!state.currentChatId) {
                const newChat = { id: Date.now(), title: content.substring(0, 30), messages: [] };
                state.chats.unshift(newChat);
                state.currentChatId = newChat.id;
            }

            const chat = state.chats.find(c => c.id === state.currentChatId);
            chat.messages.push({ role: 'user', content });
            
            // Update title if first message
            if(chat.messages.length === 1) chat.title = content.substring(0, 30);
            
            input.value = '';
            input.style.height = 'auto';
            renderMessages();
            renderHistory();

            // 2. Prepare for Streaming Response
            btn.disabled = true;
            const messagesList = document.getElementById('messages-list');
            const aiMsgDiv = document.createElement('div');
            aiMsgDiv.className = "flex justify-start w-full transition-all";
            aiMsgDiv.innerHTML = `
                <div class="w-full">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="text-[10px] font-bold uppercase tracking-widest opacity-50">RB Ai</span>
                    </div>
                    <div class="prose prose-sm dark:prose-invert max-w-none typing-cursor" id="streaming-content"></div>
                </div>
            `;
            messagesList.appendChild(aiMsgDiv);
            const streamTarget = document.getElementById('streaming-content');

            try {
                const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
                    method: "POST",
                    headers: {
                        "Authorization": `Bearer ${state.apiKey}`,
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        model: state.model,
                        messages: [
                            { role: "system", content: state.systemPrompt },
                            ...chat.messages
                        ],
                        stream: true
                    })
                });

                if (!response.ok) throw new Error('API request failed');

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let fullContent = "";

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    const chunk = decoder.decode(value);
                    const lines = chunk.split('\n');
                    
                    for (const line of lines) {
                        if (line.startsWith('data: ')) {
                            const data = line.slice(6);
                            if (data === '[DONE]') break;
                            try {
                                const json = JSON.parse(data);
                                const token = json.choices[0]?.delta?.content || "";
                                fullContent += token;
                                streamTarget.innerHTML = marked.parse(fullContent);
                                // Scroll to bottom
                                const win = document.getElementById('chat-window');
                                win.scrollTop = win.scrollHeight;
                            } catch (e) {}
                        }
                    }
                }

                chat.messages.push({ role: 'assistant', content: fullContent });
                saveChats();
                streamTarget.classList.remove('typing-cursor');

            } catch (err) {
                streamTarget.innerHTML = `<span class="text-red-500">Error: ${err.message}. Please check your API key in settings.</span>`;
            } finally {
                btn.disabled = false;
                renderMessages();
            }
        }

        // Enter to send (Shift+Enter for newline)
        document.getElementById('user-input').addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
    </script>
</body>
</html>
